# ==================================================
# ALIZZ STORE ENV TEMPLATE
# Jangan isi file ini dengan credential asli.
# File ini aman untuk GitHub karena hanya contoh/template.
#
# Credential asli isi di:
# Vercel Project Settings > Environment Variables
#
# Untuk local development, buat file .env.local
# dan JANGAN commit .env.local ke GitHub.
# ==================================================


# ==================================================
# ADMIN LOGIN
# ==================================================
# Username admin untuk login panel admin.
ADMIN_USERNAME=admin-alizz

# Password hash admin.
# Jangan isi password mentah.
# Format mengikuti sistem login lama ALIZZ STORE.
ADMIN_PASSWORD_HASH=pbkdf2_sha256$310000$contoh_salt$contoh_hash

# Secret untuk cookie/session admin.
# Minimal 32 karakter, wajib random panjang.
SESSION_SECRET=ganti_dengan_random_secret_minimal_32_karakter


# ==================================================
# SUPABASE DATABASE
# ==================================================
# Project URL dari Supabase.
# Contoh: https://abcdefghijk.supabase.co
SUPABASE_URL=https://project.supabase.co

# Service role key hanya untuk backend Vercel.
# JANGAN taruh di frontend.
# JANGAN commit key asli ke GitHub.
# JANGAN expose ke browser.
SUPABASE_SERVICE_ROLE_KEY=service_role_key_backend_only

# Anon key opsional.
# Hanya dipakai kalau nanti frontend butuh akses read-only tertentu.
SUPABASE_ANON_KEY=anon_key_optional


# ==================================================
# TELEGRAM BOT ADMIN
# ==================================================
# Token bot dari BotFather.
# Hanya boleh dipakai backend /api/telegram/*.
# JANGAN taruh di frontend.
# JANGAN commit token asli ke GitHub.
TELEGRAM_BOT_TOKEN=telegram_bot_token_backend_only

# Chat ID owner/admin Telegram.
# Bisa didapat nanti lewat command /myid.
TELEGRAM_ADMIN_CHAT_ID=telegram_admin_chat_id


# ==================================================
# WEB PUSH NOTIFICATION / VAPID
# ==================================================
# Public key boleh dipakai frontend untuk request push notification.
VAPID_PUBLIC_KEY=vapid_public_key

# Private key hanya untuk backend.
# JANGAN expose ke browser.
# JANGAN commit key asli ke GitHub.
VAPID_PRIVATE_KEY=vapid_private_key_backend_only

# Subject VAPID.
# Bisa pakai email atau URL website.
# Contoh:
# VAPID_SUBJECT=mailto:admin@alizzstore.com
# VAPID_SUBJECT=https://domain-kamu.vercel.app
VAPID_SUBJECT=mailto:admin@alizz-store.local


# ==================================================
# SITE CONFIG
# ==================================================
# URL website production kamu.
# Contoh: https://alizz-store.vercel.app
SITE_URL=https://domain-kamu.vercel.app

# Mode environment.
NODE_ENV=production
